# Discord bot runtime. Never commit a real token.
# Also enable Message Content Intent in the Discord Developer Portal.
DISCORD_TOKEN=your_discord_bot_token

# Local VPS PostgreSQL connection.
DATABASE_URL=postgresql://spamcatcher:password@127.0.0.1:5432/spam_catcher
PG_SSL_MODE=disable
BOT_POSTGRES_POOL_MAX=2

# Optional comma-separated allowlist. Empty means any guild with enabled DB config is allowed.
ALLOWED_GUILD_IDS=

# Optional. Required only when AI Verdict Checker is enabled in a guild.
# OpenRouter is preferred; Gemini remains supported as fallback.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=xiaomi/mimo-v2.5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DEBUG=false
