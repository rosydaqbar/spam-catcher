# Discord bot runtime. Never commit a real token.
DISCORD_TOKEN=your_discord_bot_token

# Postgres/Supabase connection. Supabase Transaction Pooler with sslmode=require is recommended.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:6543/postgres?sslmode=require
PG_SSL_MODE=require
PG_SSL_REJECT_UNAUTHORIZED=false
BOT_POSTGRES_POOL_MAX=2

# Guild and log channels.
# DISCORD_GUILD_ID is used by npm run post:notices.
DISCORD_GUILD_ID=your_discord_server_id
LOG_CHANNEL_ID=your_admin_log_text_channel_id

# Spam Catcher config fallback. DB config in spam_catcher_config overrides these values per guild.
SPAM_CATCHER_ENABLED=true
SPAM_CATCHER_CHANNEL_IDS=trap_channel_id_1,trap_channel_id_2
SPAM_CATCHER_TIMEOUT_MINUTES=60
SPAM_CATCHER_AUTO_BAN_ENABLED=false
# Allowed: delayed, immediate, after_timeout
SPAM_CATCHER_BAN_MODE=delayed
SPAM_CATCHER_BAN_DELAY_MINUTES=10
SPAM_CATCHER_REVIEW_CHANNEL_ID=admin_review_text_channel_id

# Optional webhook notice delivery. JSON array of {"channelId":"...","webhookUrl":"..."}.
SPAM_CATCHER_WEBHOOK_ENABLED=false
SPAM_CATCHER_WEBHOOK_URLS=[]

DEBUG=false
